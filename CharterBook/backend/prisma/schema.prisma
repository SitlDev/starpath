
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── WHITE-LABEL TENANT ────────────────────────────────────────────────────────
model Tenant {
  id           String   @id @default(uuid())
  slug         String   @unique          // subdomain: acme-air.charterbook.app
  companyName  String                    // "ACME Charter Aviation"
  logoUrl      String?                   // URL to their logo image
  primaryColor String   @default("#7c3aed") // Brand accent color (hex)
  domain       String?  @unique          // Custom domain: ops.acmeair.com
  plan         String   @default("starter") // starter | pro | enterprise
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations — all data belongs to a tenant
  users        User[]
  aircraft     Aircraft[]
  crew         CrewMember[]
  clients      Client[]
  flights      Flight[]
  emptyLegs    EmptyLeg[]
  pricingRules PricingRule[]
}

// ─── USERS ─────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  email     String
  password  String
  name      String
  role      String   @default("Dispatcher") // Dispatcher, Pilot, Admin
  superAdmin Boolean @default(false)         // Platform super-admin (cross-tenant)
  createdAt DateTime @default(now())

  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@unique([email, tenantId])
}

// ─── FLEET ─────────────────────────────────────────────────────────────────────
model Aircraft {
  id             String   @id @default(uuid())
  tailNumber     String
  type           String   // e.g. King Air 350, Gulfstream G550
  capacity       Int
  baseAirport    String   @default("KCLT")
  hourlyRate     Float    @default(0.0)
  nextInspection DateTime?
  status         String   @default("Airworthy") // Airworthy, Maintenance, AOG
  flights        Flight[]
  adItems        ADItem[]

  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])

  @@unique([tailNumber, tenantId])
}

// ─── CREW ──────────────────────────────────────────────────────────────────────
model CrewMember {
  id                String   @id @default(uuid())
  name              String
  role              String   // PIC, SIC, Flight Attendant
  email             String
  phone             String?
  certExpiry        DateTime
  medicalExpiry     DateTime
  totalFlightHours  Float    @default(0)
  last30DayHours    Float    @default(0)
  last90DayHours    Float    @default(0)
  calendarYearHours Float    @default(0)
  lastDutyStart     DateTime?
  lastRestEnd       DateTime?
  status            String   @default("Available")
  flightsPic        Flight[] @relation("PIC")
  flightsSic        Flight[] @relation("SIC")
  certificates      Certificate[]

  tenantId          String?
  tenant            Tenant?  @relation(fields: [tenantId], references: [id])

  @@unique([email, tenantId])
}

model Certificate {
  id           String     @id @default(uuid())
  name         String
  number       String
  expiry       DateTime
  crewMemberId String
  crewMember   CrewMember @relation(fields: [crewMemberId], references: [id])
}

// ─── CRM ───────────────────────────────────────────────────────────────────────
model Client {
  id             String    @id @default(uuid())
  name           String
  company        String?
  email          String
  phone          String?
  tier           String    @default("Regular") // VIP, Regular, One-Time
  totalFlights   Int       @default(0)
  totalSpend     Float     @default(0)
  lastFlightDate DateTime?
  avatarColor    String    @default("#7c3aed")
  notes          CRMNote[]
  flights        Flight[]

  tenantId       String?
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])

  @@unique([email, tenantId])
}

model CRMNote {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  author    String
  text      String
  type      String   // call, note, email
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
}

// ─── FLIGHTS ───────────────────────────────────────────────────────────────────
model Flight {
  id             String   @id @default(uuid())
  tripNumber     String
  origin         String
  destination    String
  departureTime  DateTime
  arrivalTime    DateTime
  paxCount       Int
  status         String   @default("QUOTED") // QUOTED, SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED

  aircraftId     String?
  aircraft       Aircraft?   @relation(fields: [aircraftId], references: [id])

  picId          String?
  pic            CrewMember? @relation("PIC", fields: [picId], references: [id])

  sicId          String?
  sic            CrewMember? @relation("SIC", fields: [sicId], references: [id])

  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])

  cateringNotes  String?
  fuelPrice      Float?
  totalPrice     Float?
  paid           Boolean  @default(false)
  invoice        String?  // JSON string of invoice lines

  checklist      ChecklistItem[]

  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tripNumber, tenantId])
}

model ChecklistItem {
  id          String   @id @default(uuid())
  label       String
  category    String   // preflight, document, weather, safety, airworthiness
  status      String   @default("pending") // pending, complete, flagged
  required    Boolean  @default(true)
  completedBy String?
  completedAt String?
  notes       String?
  flightId    String
  flight      Flight   @relation(fields: [flightId], references: [id])
}

model ADItem {
  id           String   @id @default(uuid())
  adNumber     String
  description  String
  dueDate      DateTime
  dueHours     Int?
  status       String   @default("Compliant") // Compliant, Due Soon, Overdue
  aircraftId   String
  aircraft     Aircraft @relation(fields: [aircraftId], references: [id])
}

// ─── MARKETPLACE ───────────────────────────────────────────────────────────────
model EmptyLeg {
  id              String   @id @default(uuid())
  tripNumber      String?
  origin          String
  originCity      String
  destination     String
  destinationCity String
  departDate      DateTime
  departTime      String
  seats           Int
  originalPrice   Float
  discountPct     Int
  status          String   @default("Available")
  tailNumber      String
  flightHours     Float
  amenities       String?  // Comma separated or JSON
  generated       Boolean  @default(true)

  tenantId        String?
  tenant          Tenant?  @relation(fields: [tenantId], references: [id])
}

// ─── GLOBAL SHARED DATA ────────────────────────────────────────────────────────
model RouteDistance {
  id       String @id @default(uuid())
  route    String @unique // e.g. "KCLT-KTEB"
  distance Int
}

model PricingRule {
  id             String   @id @default(uuid())
  aircraftType   String
  baseHourlyRate Float
  fuelBurnEntry  Float    @default(100)
  minFlightTime  Float    @default(1.0)

  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])

  @@unique([aircraftType, tenantId])
}
