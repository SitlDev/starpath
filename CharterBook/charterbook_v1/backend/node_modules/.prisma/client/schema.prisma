generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("Dispatcher") // Dispatcher, Pilot, Admin
  createdAt DateTime @default(now())
}

model Aircraft {
  id             String    @id @default(uuid())
  tailNumber     String    @unique
  type           String // e.g. King Air 350, Gulfstream G550
  capacity       Int
  baseAirport    String    @default("KCLT") // Base ICAO
  hourlyRate     Float     @default(0.0)
  nextInspection DateTime?
  status         String    @default("Airworthy") // Airworthy, Maintenance, AOG
  flights        Flight[]
  adItems        ADItem[]
}

model CrewMember {
  id                String        @id @default(uuid())
  name              String
  role              String // PIC, SIC, Flight Attendant
  email             String        @unique
  phone             String?
  certExpiry        DateTime
  medicalExpiry     DateTime
  totalFlightHours  Float         @default(0)
  last30DayHours    Float         @default(0)
  last90DayHours    Float         @default(0)
  calendarYearHours Float         @default(0)
  lastDutyStart     DateTime?
  lastRestEnd       DateTime?
  status            String        @default("Available")
  flightsPic        Flight[]      @relation("PIC")
  flightsSic        Flight[]      @relation("SIC")
  certificates      Certificate[]
}

model Certificate {
  id           String     @id @default(uuid())
  name         String
  number       String
  expiry       DateTime
  crewMemberId String
  crewMember   CrewMember @relation(fields: [crewMemberId], references: [id])
}

model Client {
  id             String    @id @default(uuid())
  name           String
  company        String?
  email          String    @unique
  phone          String?
  tier           String    @default("Regular") // VIP, Regular, One-Time
  totalFlights   Int       @default(0)
  totalSpend     Float     @default(0)
  lastFlightDate DateTime?
  avatarColor    String    @default("#7c3aed")
  notes          CRMNote[]
  flights        Flight[]
}

model CRMNote {
  id       String   @id @default(uuid())
  date     DateTime @default(now())
  author   String
  text     String
  type     String // call, note, email
  clientId String
  client   Client   @relation(fields: [clientId], references: [id])
}

model Flight {
  id            String   @id @default(uuid())
  tripNumber    String   @unique
  origin        String
  destination   String
  departureTime DateTime
  arrivalTime   DateTime
  paxCount      Int
  status        String   @default("QUOTED") // QUOTED, SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED

  aircraftId String?
  aircraft   Aircraft? @relation(fields: [aircraftId], references: [id])

  picId String?
  pic   CrewMember? @relation("PIC", fields: [picId], references: [id])

  sicId String?
  sic   CrewMember? @relation("SIC", fields: [sicId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  cateringNotes String?
  fuelPrice     Float?
  totalPrice    Float?
  paid          Boolean @default(false)
  invoice       String? // JSON string of invoice lines

  checklist ChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistItem {
  id          String  @id @default(uuid())
  label       String
  category    String // preflight, document, weather, safety, airworthiness
  status      String  @default("pending") // pending, complete, flagged
  required    Boolean @default(true)
  completedBy String?
  completedAt String?
  notes       String?
  flightId    String
  flight      Flight  @relation(fields: [flightId], references: [id])
}

model ADItem {
  id          String   @id @default(uuid())
  adNumber    String
  description String
  dueDate     DateTime
  dueHours    Int?
  status      String   @default("Compliant") // Compliant, Due Soon, Overdue
  aircraftId  String
  aircraft    Aircraft @relation(fields: [aircraftId], references: [id])
}

model EmptyLeg {
  id              String   @id @default(uuid())
  tripNumber      String?
  origin          String
  originCity      String
  destination     String
  destinationCity String
  departDate      DateTime
  departTime      String
  seats           Int
  originalPrice   Float
  discountPct     Int
  status          String   @default("Available")
  tailNumber      String
  flightHours     Float
  amenities       String? // Comma separated or JSON
  generated       Boolean  @default(true)
}

model RouteDistance {
  id       String @id @default(uuid())
  route    String @unique // e.g. "KCLT-KTEB"
  distance Int
}

model PricingRule {
  id             String @id @default(uuid())
  aircraftType   String @unique
  baseHourlyRate Float
  fuelBurnEntry  Float  @default(100)
  minFlightTime  Float  @default(1.0)
}
