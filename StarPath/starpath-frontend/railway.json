{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildArgs": {
      "NEXT_PUBLIC_API_URL": "$BACKEND_URL"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "sh -c 'node server.js -p ${PORT:-3000}'",
    "restartPolicyMaxRetries": 5,
    "healthchecks": {
      "readiness": {
        "initialDelaySeconds": 5,
        "periodSeconds": 30
      }
    }
  }
}
